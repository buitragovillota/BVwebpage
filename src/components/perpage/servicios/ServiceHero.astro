---
interface Props {
  title: string;
  description: string;
  microcopy?: string;
  icon?: any;
}

const { title, description, microcopy, icon } = Astro.props;
---

<section class="bg-deep-indigo relative min-h-[60vh] overflow-hidden py-24 sm:py-32">
  <!-- Background Pattern -->
  <div
    class="pointer-events-none absolute inset-0 opacity-5"
    style="background-image: radial-gradient(circle at 2px 2px, #d4af37 1px, transparent 0); background-size: 40px 40px;"
  >
  </div>

  <div class="container relative z-10 mx-auto max-w-5xl px-6">
    <!-- Icon -->
    {
      icon && (
        <div class="mb-8 flex justify-center">
          <div class="bg-gold/10 border-gold/20 flex h-20 w-20 items-center justify-center rounded-2xl border">
            <img src={icon.src} alt="" class="h-10 w-10 opacity-90" />
          </div>
        </div>
      )
    }

    <!-- Title -->
    <h1
      class="text-snow mb-6 text-center font-serif text-4xl font-normal leading-tight tracking-tight sm:text-5xl lg:text-6xl"
    >
      {title}
    </h1>

    <!-- Microcopy Badge -->
    {
      microcopy && (
        <div class="mb-8 flex justify-center">
          <span class="bg-gold/10 text-gold border-gold/20 inline-block rounded-full border px-4 py-2 text-xs font-semibold uppercase tracking-widest">
            {microcopy}
          </span>
        </div>
      )
    }

    <!-- Description -->
    <p
      class="text-snow/80 mx-auto max-w-3xl text-center text-lg leading-relaxed sm:text-xl"
    >
      {description}
    </p>
  </div>
</section>
