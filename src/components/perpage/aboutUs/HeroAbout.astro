---
import ArrowRight from "@/assets/icons/arrow-right.svg";
---

<section
  class="hero-about from-deep-dark to-titaneo relative flex min-h-screen w-full items-end bg-linear-to-br px-6 pt-40 pb-24 sm:px-8 lg:px-16 lg:pb-32"
>
  <!-- Decorative gradient orbs -->
  <div
    class="bg-deep-indigo/25 pointer-events-none absolute top-1/3 left-1/4 h-128 w-lg rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div
    class="bg-gold/8 pointer-events-none absolute right-1/6 bottom-1/4 h-80 w-80 rounded-full blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto w-full max-w-7xl">
    <!-- Eyebrow -->
    <div class="mb-10 flex items-center gap-4">
      <div class="bg-gold h-px w-16"></div>
      <p class="text-gold text-xs font-semibold tracking-widest uppercase">
        La Firma
      </p>
    </div>

    <!-- Headline -->
    <div>
      <h1
        class="text-snow text-4xl leading-none font-normal tracking-tight sm:text-5xl lg:text-8xl"
      >
        Más que litigantes,
        <br />
        <span class="text-gold italic">estrategas</span> de derecho
        <br />
        electoral.
      </h1>
    </div>

    <!-- Description block: below H1 -->
    <div class="mt-12 max-w-2xl">
      <p class="text-snow/70 mb-8 text-base leading-relaxed sm:text-lg">
        En <span class="text-gold font-semibold">Buitrago &amp; Villota</span> no
        improvisamos. Estructuramos la defensa o la impugnación que usted requiera,
        a nivel judicial o ante la autoridad electoral, con el mayor rigor <span
          class="font-semibold italic"
        >
          técnico-jurídico</span
        >, basados en hechos pertinentes, pruebas idóneas y argumentos
        contundentes.
      </p>
      <a
        href="/contacto"
        class="group text-titaneo bg-gold hover:bg-gold/90 hover:shadow-gold/20 inline-flex w-fit items-center gap-3 rounded-full px-6 py-3 text-sm font-semibold tracking-wide uppercase transition-all duration-300 hover:shadow-2xl"
      >
        Agendar consulta
        <ArrowRight
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
        />
      </a>
    </div>

    <!-- Thin gold divider -->
    <div class="bg-gold/20 mt-20 h-px w-full"></div>
  </div>
</section>
