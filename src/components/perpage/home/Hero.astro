---
import ArrowRight from "@/assets/icons/arrow-right.svg";
import Scales from "@/assets/icons/scales.svg";
import ArrowUp from "@/assets/icons/arrow-up.svg";
import Award from "@/assets/icons/award.svg";
---

<section
  class="hero-section from-titaneo to-deep-dark relative flex min-h-screen w-full items-center justify-center bg-linear-to-br px-6 py-28 sm:px-8 lg:px-12"
>
  <!-- Decorative gradient orbs for depth -->
  <div
    class="bg-deep-indigo/30 absolute top-1/4 left-1/4 h-96 w-96 rounded-full blur-3xl"
  >
  </div>
  <div
    class="bg-gold/10 absolute right-1/4 bottom-1/4 h-80 w-80 rounded-full blur-3xl"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <!-- Golden label -->
    <div class="mb-8 flex items-center justify-center gap-3">
      <div class="bg-gold h-px w-12"></div>
      <p
        class="text-gold text-sm font-medium tracking-wider uppercase sm:text-base"
      >
        Buitrago & Villota
      </p>
      <div class="bg-gold h-px w-12"></div>
    </div>

    <!-- Main heading -->
    <div class="flex flex-col items-center justify-center p-14">
      <h1
        class="text-snow mb-8 text-5xl leading-tight font-normal tracking-tight sm:text-6xl md:text-7xl lg:text-8xl"
      >
        Excelencia iuris en
        <span class="text-gold block italic">derecho electoral.</span>
      </h1>

      <!-- Description -->
      <p
        class="text-snow/80 mx-auto mb-12 max-w-2xl text-base leading-relaxed sm:text-lg md:text-xl"
      >
        Expertos en defensa e impugnación electoral y nombramientos de altos
        dignatarios del Estado.
      </p>

      <!-- CTA Button -->
      <a
        href="/contacto"
        class="group bg-gold text-titaneo hover:bg-gold/90 hover:shadow-gold/20 inline-flex items-center gap-3 rounded-full px-6 py-3 text-base font-semibold tracking-wide uppercase transition-all duration-300 hover:shadow-2xl sm:text-lg"
      >
        Agendar consulta
        <ArrowRight
          class="h-5 w-5 transition-transform duration-300 group-hover:translate-x-1"
        />
      </a>
    </div>

    <!-- Stats Bar -->
    <div
      class="mt-16 sm:mt-20 lg:absolute lg:right-0 lg:-bottom-60 lg:left-0 lg:mt-24"
    >
      <div
        class="bg-snow mx-auto max-w-7xl rounded-3xl p-8 shadow-2xl backdrop-blur-sm"
      >
        <div class="flex flex-col gap-8">
          <!-- Top row: two stats side by side -->
          <div class="flex flex-col gap-8 sm:flex-row">
            <!-- Stat 1: Years of Experience -->
            <div class="flex flex-1 flex-col items-center p-4 text-center">
              <div
                class="bg-gold/10 mb-6 flex h-12 w-12 items-center justify-center rounded-full"
              >
                <Scales class="text-gold h-8 w-8" />
              </div>
              <h3
                class="text-titaneo mb-1 font-serif text-3xl tracking-tight italic sm:text-4xl"
              >
                +10 Años
              </h3>
              <p
                class="text-deep-indigo text-xs font-medium tracking-wider uppercase sm:text-sm"
              >
                De Litigio Independiente
              </p>
            </div>

            <!-- Stat 2: Success Rate -->
            <div class="flex flex-1 flex-col items-center p-4 text-center">
              <div
                class="bg-gold/10 mb-6 flex h-12 w-12 items-center justify-center rounded-full"
              >
                <ArrowUp class="text-gold h-8 w-8" />
              </div>
              <h3
                class="text-titaneo mb-1 font-serif text-3xl tracking-tight italic sm:text-4xl"
              >
                +95%
              </h3>
              <p
                class="text-deep-indigo text-xs font-medium tracking-wider uppercase sm:text-sm"
              >
                De Éxito en Procesos
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
