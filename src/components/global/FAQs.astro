---
import type { FAQItem } from "@/config/faqs";
import PlusIcon from "@/assets/icons/plus.svg";
// import LinkIcon from "@/assets/icons/link.svg";

interface Props {
  title?: string;
  subtitle?: string;
  faqs: FAQItem[];
}

const {
  title = "Preguntas Frecuentes",
  subtitle = "Claridad y Respaldo: Lo que debe saber sobre nuestra firma",
  faqs,
} = Astro.props;
---

<section class="faq-section bg-snow w-full py-16 md:py-24">
  <div class="mx-auto max-w-4xl px-4">
    <!-- Header -->
    <div class="mb-12 text-center">
      <h2
        class="text-titaneo mb-4 text-3xl leading-tight font-medium md:text-4xl lg:text-5xl"
      >
        {title}
      </h2>
      {
        subtitle && (
          <p class="text-gold mx-auto max-w-2xl text-base md:text-lg">
            {subtitle}
            <span class="text-titaneo block text-base">
              Resolvemos las inquietudes iniciales sobre nuestro modelo de
              representación, alcance y protocolos de confidencialidad.
            </span>
          </p>
        )
      }
    </div>

    <!-- FAQ Accordion -->
    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <details class="group border-gold/30 overflow-hidden rounded-xl border bg-white backdrop-blur-sm">
            <summary class="text-titaneo hover:bg-gold/5 flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 text-lg font-medium transition-colors duration-200 md:text-xl">
              <span class="pr-4 text-left">{faq.question}</span>
              <span class="border-gold text-gold flex h-6 w-6 shrink-0 items-center justify-center rounded-full border-2 transition-transform duration-300 group-open:rotate-45">
                <PlusIcon class="h-4 w-4" />
              </span>
            </summary>
            <div class="px-6 pt-2 pb-6">
              <p class="text-deep-indigo/50 text-base leading-relaxed">
                {faq.answer}
              </p>
              {/* <div class="flex items-center gap-3">
                {faq.links?.map((link) => (
                  <a
                    href={link.href}
                    class="group text-gold hover:text-deep-indigo mt-4 flex items-center gap-1 text-sm font-medium transition-colors duration-200 hover:underline hover:underline-offset-2"
                  >
                    {link.text}
                    <LinkIcon class="h-3 w-3 group-hover:scale-110" />
                  </a>
                ))}
              </div>
              {faq.note && (
                <p class="text-deep-indigo/60 mt-4 text-sm italic">
                  {faq.note}
                </p>
              )} */}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Hide default marker in all browsers */
  details summary::-webkit-details-marker {
    display: none;
  }

  details summary::marker {
    display: none;
    content: "";
  }

  /* Smooth open/close transition */
  details[open] summary {
    border-bottom: 1px solid oklch(0.8089 0.1566 80.71 / 0.15);
  }
</style>
