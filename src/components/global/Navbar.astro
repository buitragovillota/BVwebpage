---
import { MainNavigation, ServicesNavigation } from "@/utils/navigation";
import { Image } from "astro:assets";
import ChevronDown from "@/assets/icons/chevron-down.svg";
import BurgerMenu from "@/assets/icons/menu.svg";
import CloseMenu from "@/assets/icons/close.svg";

const pathname = Astro.url.pathname;
const currentPath =
  pathname.endsWith("/") && pathname.length > 1
    ? pathname.slice(0, -1)
    : pathname;
---

<header
  class="nav-container bg-titaneo border-gold/10 fixed top-0 right-0 left-0 z-50 w-full border-b shadow-lg"
>
  <nav
    id="navbar"
    class="nav-content mx-auto flex max-w-7xl items-center justify-between py-2"
  >
    <!-- Logo -->
    <div id="logo-container" class="flex items-center gap-2 pl-8">
      <a href="/" aria-label="inicio">
        <!-- <Image src={Logo} alt="LogoExploenergy" class="w-40 md:w-56" priority /> -->
        <h1
          class="text-gold border-gold rounded-full border p-2 text-2xl font-bold"
        >
          BV
        </h1>
      </a>
      <p
        class="text-snow transition-transform duration-300 group-open:rotate-180"
      >
        Buitrago & Villota
      </p>
    </div>
    <!-- end Logo -->

    <!-- Right side navigation -->
    <div class="flex items-center gap-6 pr-2 md:pr-8">
      <!-- Desktop links (hidden on mobile) -->
      <div id="desktop-nav" class="hidden items-center gap-6 md:flex">
        {
          MainNavigation.filter(
            (item) => item.path !== "/contacto" && item.path !== "/servicios",
          ).map((item) => (
            <a
              href={item.path}
              class={`nav-link hover:text-gold text-lg transition-colors duration-200 ${
                currentPath === item.path && item.path !== "/"
                  ? "text-gold"
                  : "text-snow"
              }`}
              aria-current={item.path === currentPath ? "page" : undefined}
            >
              {item.name}
            </a>
          ))
        }

        <!-- Services dropdown -->
        <details class="group relative" id="services-dropdown">
          <summary
            class="text-snow hover:text-gold flex cursor-pointer list-none items-center gap-1.5 text-lg transition-colors duration-200 focus:outline-none [&::-webkit-details-marker]:hidden"
          >
            Servicios
            <ChevronDown
              class="h-4 w-4 transition-transform duration-300 group-open:rotate-180"
            />
          </summary>

          <!-- Dropdown Panel -->
          <div
            class="absolute top-full right-0 z-50 w-96 origin-top scale-95 pt-2 opacity-0 transition-all duration-200 ease-out group-open:scale-100 group-open:opacity-100"
          >
            <!-- Dropdown content -->
            <div
              class="bg-deep-dark/95 border-gold relative overflow-hidden rounded-2xl border shadow-2xl shadow-black/50 backdrop-blur-2xl"
            >
              <!-- Header -->
              <div
                class="border-gold flex items-center justify-between border-b px-5 py-4"
              >
                <span class="text-gold text-sm font-semibold"
                  >Nuestros servicios</span
                >
              </div>

              <!-- Services list -->
              <ul class="list-none border-none py-2">
                {
                  ServicesNavigation.map((item, index) => (
                    <li>
                      <a
                        href={item.path}
                        class={`flex items-center justify-between px-5 py-3 transition-all duration-200 outline-none hover:bg-white/5 focus:outline-none ${
                          currentPath === item.path
                            ? "text-gold bg-white/5 underline underline-offset-2"
                            : "text-snow"
                        }`}
                        aria-current={
                          item.path === currentPath ? "page" : undefined
                        }
                      >
                        <span class="flex items-center gap-3 text-sm">
                          <span class="bg-gold h-1 w-1 rounded-full" />
                          {item.name}
                        </span>
                      </a>
                      {index < ServicesNavigation.length - 1 && (
                        <div class="mx-5" />
                      )}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </details>
        <!-- end Services dropdown -->
      </div>
      <!-- end Desktop links -->

      <!-- Contacto link (always visible) -->
      <div class="flex items-center gap-1">
        <a
          href="/contacto"
          class="nav-link text-deep-dark bg-gold hover:bg-gold/80 rounded-full px-4 py-2 font-semibold transition-colors hover:backdrop-blur-sm"
          >Contacto</a
        >

        <!-- Burger menu (mobile only) -->
        <button
          id="mobile-menu-toggle"
          class="bg-deep-indigo text-snow flex size-9 items-center justify-center rounded-full text-sm disabled:pointer-events-none disabled:opacity-50 md:hidden"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Abrir menú"
        >
          <BurgerMenu id="menu-icon-open" class="h-4 w-4" />
          <CloseMenu id="menu-icon-close" class="hidden h-4 w-4" />
        </button>
      </div>
    </div>
    <!-- end Right side navigation -->
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="bg-deep-dark pointer-events-none fixed inset-x-0 top-0 z-40 flex max-h-[85vh] -translate-y-full transform flex-col overflow-hidden rounded-b-3xl border-b border-white/10 opacity-0 shadow-2xl transition-all duration-300 ease-out md:hidden"
  >
    <!-- Header -->
    <div
      class="flex shrink-0 items-center justify-between border-b border-white/10 px-6 py-5"
    >
      <a href="/" aria-label="inicio" data-menu-link>
        <!-- <Image src={Logo} alt="LogoExploenergy" class="w-40" priority /> -->
        <h1 class="text-snow text-2xl font-bold">BV</h1>
      </a>
      <div class="flex items-center gap-3">
        <a
          href="/contacto"
          class="text-deep-dark bg-gold hover:bg-gold/80 rounded-full px-2 py-1 text-sm font-semibold transition-colors active:scale-95"
          data-menu-link
        >
          Contacto
        </a>
        <button
          id="mobile-menu-close"
          class="text-snow flex size-10 items-center justify-center rounded-full bg-white/5 transition-all hover:bg-white/10 active:scale-95"
          aria-label="Cerrar menú"
        >
          <CloseMenu class="h-5 w-5" />
        </button>
      </div>
    </div>

    <!-- Links -->
    <div class="flex-1 overflow-y-auto overscroll-contain px-6 py-4">
      {
        MainNavigation.filter((item) => item.path !== "/contacto").map(
          (item) => (
            <a
              href={item.path}
              class={`mb-1 block rounded-lg px-3 py-3.5 text-base transition-all duration-200 ${
                currentPath === item.path
                  ? "bg-gold/10 text-gold"
                  : "text-snow/90 hover:text-snow hover:bg-white/5"
              }`}
              aria-current={item.path === currentPath ? "page" : undefined}
              data-menu-link
            >
              {item.name}
            </a>
          ),
        )
      }

      <!-- Services Accordion -->
      <div class="py-2">
        <button
          id="mobile-services-toggle"
          class="text-snow/90 hover:text-snow flex w-full items-center justify-between rounded-lg px-3 py-3.5 text-base transition-all duration-200 hover:bg-white/5"
          aria-expanded="false"
        >
          <span>Servicios</span>
          <ChevronDown
            id="mobile-services-chevron"
            class="h-4 w-4 transition-transform duration-300"
          />
        </button>
        <div
          id="mobile-services-submenu"
          class="max-h-0 overflow-hidden opacity-0 transition-all duration-300 ease-out"
        >
          <div class="space-y-1 pt-2 pl-3">
            {
              ServicesNavigation.map((item) => (
                <a
                  href={item.path}
                  class={`block rounded-lg px-3 py-2.5 text-sm transition-all duration-200 ${
                    currentPath === item.path
                      ? "bg-gold/10 text-gold"
                      : "text-snow/70 hover:text-snow hover:bg-white/5"
                  }`}
                  aria-current={item.path === currentPath ? "page" : undefined}
                  data-menu-link
                >
                  <span class="flex items-center gap-2">
                    <span class="bg-gold/60 h-1.5 w-1.5 rounded-full" />
                    {item.name}
                  </span>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import { navbarAnimations } from "@/utils/scripts/animations/home/navBarAnimation";

  navbarAnimations();
</script>
