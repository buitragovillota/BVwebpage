---
import "@/styles/global.css";
import { Font } from "astro:assets";
import SeoHead from "@/components/SeoHead.astro";
import Navbar from "@/components/global/Navbar.astro";
import Footer from "@/components/global/Footer.astro";

import {
  ORGANIZATION_SCHEMA,
  WEBSITE_SCHEMA,
  type JSONLDSchema,
} from "@/config/seoConf";
import type { SEOProps } from "astro-seo";

interface Props {
  seoProps: SEOProps;
  schemas?: JSONLDSchema[];
}

const { seoProps, schemas = [] } = Astro.props;

const allSchemas = [...schemas, ORGANIZATION_SCHEMA, WEBSITE_SCHEMA];
---

<!doctype html>
<html lang="es-CO" class="scrollbar-hide overflow-x-hidden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- SEO Head -->
    <SeoHead seoProps={seoProps} schemas={allSchemas} />

    <!-- Font Optimization -->
    <Font cssVariable="--font-cormorant-garamond" preload />
    <Font cssVariable="--font-dm-sans" preload />

    <script>
      import "@/utils/scripts/lennis.js";
    </script>
  </head>

  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
